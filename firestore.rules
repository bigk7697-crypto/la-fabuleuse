rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for menu collection - anyone can read, authenticated users can write
    match /menu/{menuId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Rules for orders collection - only authenticated users
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Rules for settings collection - anyone can read, authenticated users can write
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Default deny rule for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
