rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Menu collection - anyone can read, authenticated users can write
    match /menu/{menuId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.token.email == 'admin@lafabuleuse.tg';
      allow update: if request.auth != null && request.auth.token.email == 'admin@lafabuleuse.tg';
      allow delete: if request.auth != null && request.auth.token.email == 'admin@lafabuleuse.tg';
    }
    
    // Orders collection - only authenticated users
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Settings collection - anyone can read, only admin can write
    match /settings/{settingsId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.token.email == 'admin@lafabuleuse.tg';
      allow update: if request.auth != null && request.auth.token.email == 'admin@lafabuleuse.tg';
      allow delete: if request.auth != null && request.auth.token.email == 'admin@lafabuleuse.tg';
    }
    
    // Users collection - only authenticated users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
